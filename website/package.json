{
  "name": "website",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -w libs:build && next dev -p 3000",
    "build": "pnpm -w libs:build && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "pnpm -w libs:build && tsc --noEmit",
    "cf:build": "pnpm -w libs:build && opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@ogpeek/react": "workspace:*",
    "ipaddr.js": "2.3.0",
    "next": "15.5.15",
    "ogpeek": "workspace:*",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@types/node": "22.7.5",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "typescript": "5.9.2",
    "wrangler": "^4.84.1"
  }
}
