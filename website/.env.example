# User-Agent used when fetching upstream pages. Default is a browser-like
# value that passes through most CDNs. Adjust if a specific site returns 403.
# OGPEEK_USER_AGENT="Mozilla/5.0 ..."

# Per-IP request limit per minute. Zero or below disables the limit.
# Default is 20.
# OGPEEK_RATE_LIMIT_PER_MIN=20

# The SSRF guard in website/lib/ssrf-guard.ts is always on. To parse internal
# staging hosts, edit ssrf-guard.ts on the deployed instance directly or add
# environment-aware allow-list logic. Never disable the guard in a public
# deployment.
