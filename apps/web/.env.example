# UI mode
# - public (default): 랜딩 섹션 + 디버거 + rate limit 적용
# - internal: 랜딩 숨김, 디버거만, rate limit 해제
NEXT_PUBLIC_MODE=public

# 외부 페이지 요청 시 사용할 User-Agent. 기본은 브라우저와 유사한 값이라
# 대부분의 CDN을 통과합니다. 특정 사이트에서 403이 나면 조정하세요.
# OGPEEK_USER_AGENT="Mozilla/5.0 ..."

# 1로 설정하면 localhost / 사설 IP / CGNAT / 링크로컬 대역 차단을 해제합니다.
# 사내 staging 도메인을 파싱할 때만 켜세요. public 배포에선 절대 켜지 마세요.
# OGPEEK_ALLOW_PRIVATE_NETWORK=1

# public 모드에서 IP당 분당 요청 제한. 0 이하면 무제한. 기본 20.
# OGPEEK_RATE_LIMIT_PER_MIN=20
