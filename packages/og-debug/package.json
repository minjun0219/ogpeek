{
  "name": "og-debug",
  "version": "0.1.0",
  "description": "Open Graph Protocol parser with spec validation warnings.",
  "keywords": ["open-graph", "ogp", "og", "parser", "debug", "validator"],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "htmlparser2": "9.1.0"
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "tsup": "8.3.0",
    "typescript": "5.9.2",
    "vitest": "2.1.3"
  }
}
