{
  "name": "ogpeek",
  "version": "0.4.0",
  "description": "Peek into any page's Open Graph tags — parser, fetcher, and validator.",
  "keywords": [
    "open-graph",
    "ogp",
    "og",
    "parser",
    "debug",
    "validator",
    "ogpeek"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minjun0219/ogpeek.git",
    "directory": "packages/ogpeek"
  },
  "homepage": "https://github.com/minjun0219/ogpeek/tree/main/packages/ogpeek#readme",
  "bugs": {
    "url": "https://github.com/minjun0219/ogpeek/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js",
      "default": "./dist/fetch.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "htmlparser2": "9.1.0"
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "rimraf": "^6.1.3",
    "typescript": "5.9.2",
    "vitest": "2.1.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
