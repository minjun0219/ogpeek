{
  "name": "ogpeek-core",
  "version": "0.2.0",
  "description": "Parser, fetcher and validator that power ogpeek — peek into any page's Open Graph tags.",
  "private": true,
  "keywords": ["open-graph", "ogp", "og", "parser", "debug", "validator", "ogpeek"],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./fetch": {
      "types": "./src/fetch.ts",
      "import": "./src/fetch.ts",
      "default": "./src/fetch.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "htmlparser2": "9.1.0"
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "typescript": "5.9.2",
    "vitest": "2.1.3"
  }
}
