{
  "name": "@ogpeek/react",
  "version": "0.1.0",
  "description": "Drop-in OG-tag inspector React components for ogpeek.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p . && node -e \"require('node:fs').copyFileSync('src/styles.css', 'dist/styles.css')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ogpeek": "workspace:*",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "jsdom": "25.0.1",
    "ogpeek": "workspace:*",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rimraf": "^6.1.3",
    "typescript": "5.9.2",
    "vitest": "2.1.3"
  }
}
