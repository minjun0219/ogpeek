{
  "name": "@ogpeek/react",
  "version": "0.1.0",
  "description": "Drop-in OG-tag inspector React components for ogpeek.",
  "keywords": [
    "open-graph",
    "ogp",
    "og",
    "react",
    "components",
    "ogpeek"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minjun0219/ogpeek.git",
    "directory": "packages/ogpeek-react"
  },
  "homepage": "https://github.com/minjun0219/ogpeek/tree/main/packages/ogpeek-react#readme",
  "bugs": {
    "url": "https://github.com/minjun0219/ogpeek/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p . && node -e \"require('node:fs').copyFileSync('src/styles.css', 'dist/styles.css')\"",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ogpeek": "workspace:^",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "jsdom": "25.0.1",
    "ogpeek": "workspace:*",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rimraf": "^6.1.3",
    "typescript": "5.9.2",
    "vitest": "2.1.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
