{
  "name": "ogpeek-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "peek into any page's Open Graph tags",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "pnpm -F website build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm -F website dev",
    "libs:build": "pnpm -r --filter 'website^...' run build",
    "libs:typecheck": "pnpm libs:build && pnpm -r --filter 'website^...' run typecheck",
    "format": "biome format --write",
    "lint": "biome lint",
    "check": "biome check",
    "check:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "typescript": "5.9.2"
  }
}
